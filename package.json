{
  "name": "agent-builder",
  "private": true,
  "scripts": {
    "format": "prettier --write \"**/*.md\"",
    "format:check": "prettier --check \"**/*.md\"",
    "lint": "markdownlint \"**/*.md\" --fix",
    "lint:check": "markdownlint \"**/*.md\"",
    "check": "npm run format:check && npm run lint:check"
  },
  "devDependencies": {
    "markdownlint-cli": "^0.44.0",
    "prettier": "^3.5.0"
  }
}
